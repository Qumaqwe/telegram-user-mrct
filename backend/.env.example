# Скопируй этот файл в .env и заполни значения

# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Токен приложения от @CryptoBot → Manage Apps → API Token
CRYPTOBOT_TOKEN=your_cryptobot_token_here

# URL твоего мини-приложения (после деплоя)
WEBAPP_URL=https://your-frontend-url.com

# Секретный ключ для защиты (любая случайная строка)
SECRET_KEY=my_super_secret_key_change_this

# Порт сервера
PORT=3001

# Telegram ID администраторов (через запятую)
# Узнать свой ID: напиши @userinfobot в Telegram
ADMIN_IDS=your_telegram_id_here

# PostgreSQL (Railway автоматически добавит DATABASE_URL при создании БД)
DATABASE_URL=postgresql://user:password@host:5432/dbname

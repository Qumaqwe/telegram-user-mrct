# Скопируй этот файл в .env и заполни значения

# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# URL твоего мини-приложения (после деплоя на Railway/Render)
WEBAPP_URL=https://your-frontend-url.com

# Секретный ключ для защиты (любая случайная строка)
SECRET_KEY=my_super_secret_key_change_this

# Порт сервера
PORT=3001

# Telegram ID администраторов (через запятую, можно несколько)
# Узнать свой ID: напиши @userinfobot в Telegram
ADMIN_IDS=8057796657
